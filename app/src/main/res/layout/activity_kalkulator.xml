<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"> <TextView
        android:id="@+id/tvTitleHalaman"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/montserrat"
        android:text="Kalkulator Geometri"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#064e3b"
        android:gravity="center" />

        <TextView
            android:id="@+id/tvDescHalaman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hitung Luas Jajar Genjang &amp; Volume Kubus"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jajar Genjang"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Alas (cm)"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAlas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_container"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tinggi (cm)"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTinggi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_container"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHitungDatar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Hitung Luas"
            app:backgroundTint="#064e3b"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvHasilDatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hasil: -"
            android:padding="16dp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:background="@drawable/bg_rounded_container"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kubus"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Panjang Sisi (cm)"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSisi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_container"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHitungRuang"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Hitung Volume"
            app:backgroundTint="#064e3b"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvHasilRuang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hasil: -"
            android:padding="16dp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:background="@drawable/bg_rounded_container"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>